# Rust
target/
**/*.rs.bk
*.pdb

# Build artifacts
build/
out/
dist/
*.o
*.a
*.elf
*.bin
*.img
*.efi

# seL4 / kernel build
build.bk/
*.dtb
*.dtbo

# Verification artifacts
*.vo
*.vok
*.vos
*.glob
*.aux
.coq-native/
.crusti_caesar/
*.proof
*.smt2.cache

# adsmt-emit WASM package manager (rc.32+, R7 sign-off 2026-06-09):
# .adsmt-emitters/ = content-addressed wasm artifact store (gitignored).
# adsmt-emit.toml + adsmt-emit.lock 는 committed (reproducibility).
.adsmt-emitters/
# adsmt cert JSON output (per-(check-sat) certificates) + emit output dir
target/adsmt-cert/
# Rocq generated build files
Makefile.rocq
Makefile.rocq.conf
.Makefile.rocq.d
Makefile.coq
Makefile.coq.conf
.Makefile.coq.d
# Verus emits the rlib next to the source by default
proofs/verus/lib*.rlib

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Local notes / private deployment
.private/
.claude-notes/_completed/
*.local.md

# Cross-project request / reply scratch (local mirror to sibling repos)
# - .local-requests-to/<peer>/  = Y4 outbound (mirror to <peer>/.local-requests-from/Y4/)
# - .local-replies-from/<peer>/ = inbound reply (mirror from <peer>/.local-replies-to/Y4/)
.local-requests-to/
.local-requests-from/
.local-replies-to/
.local-replies-from/

# Claude Code per-user state (settings.local.json holds machine-local allowlists)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Claude Code session ID captured by SessionStart hook (.claude/settings.json).
# Used by `make claude-resume` / `just claude-resume` after [Ctrl+C] x2.
# Per-developer scratch — never commit.
.claude-recent-session-id

# Tooling caches
.cache/
.direnv/
.pre-commit-cache/

# Submodule scratch
third_party/*/build/
third_party/*/.git/

# Vendored-on-demand scudo source — `just scudo-fetch` materialises this
# from third_party/scudo/PIN.toml.  PIN.toml is committed; the source is not.
third_party/scudo/standalone/
third_party/scudo/standalone.tmp/
