{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "cd /home/ybi/Y4 && just mirror-memory >/dev/null || echo '[y4 mirror-memory] FAIL — run just mirror-memory manually to inspect'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r .session_id > /home/ybi/Y4/.claude-recent-session-id"
          }
        ]
      }
    ]
  }
}
